# App
NODE_ENV=development
PORT=3000
APP_NAME=ClinicOS

# Database — Supabase pooler (Dashboard → Connect). Encode @ in password as %40.
# App runtime — transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connect_timeout=30"
# Migrations / prisma db push — session pooler (port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30"

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_change_this
JWT_REFRESH_EXPIRES_IN=7d

# Redis — Upstash or local Redis
REDIS_URL=redis://localhost:6379

# Email — Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@clinicos.app

# AI — Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# WhatsApp — Meta Cloud API
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Supabase — API keys & JWT verification (@supabase/server)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://[ref].supabase.co/auth/v1/.well-known/jwks.json
